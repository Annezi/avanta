# Copy to .env and adjust. Run API from the backend/ directory.

# Required — long random string
JWT_SECRET=change_me_to_a_long_random_string

# bcrypt hash for password "AvantaGuccinPrint" (change password → generate new hash)
ADMIN_PASSWORD_HASH=$2b$12$bve4vxKnctslCgiH/ec9OO0QTt/b4oHvRbLPSxwmi4AgG7cMSCaV.

# Telegram — create bot via @BotFather (never commit real token to git)
BOT_TOKEN=your_bot_token_here

# Secret phrase for: /start YOUR_SECRET (admin registers chat)
BOT_REGISTRATION_SECRET=change_me_registration_secret

# Optional: LibreOffice executable on Windows
LIBREOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe

# CORS — GitHub Pages origin(s), comma-separated, or * for dev
# CORS_ORIGINS=http://localhost:3000

DATA_DIR=./data
RETENTION_DAYS=30
